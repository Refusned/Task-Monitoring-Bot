# OpenClaw agent .env — copy to .env and fill values.

# === LLM ===
# Get your key at https://ollama.com (Pro plan recommended for tool-calling parity).
OLLAMA_API_KEY=

# === Telegram ===
# Create a bot via @BotFather; this token is for the OpenClaw channel AND for
# the scheduler-side push notifications about completed orders.
TELEGRAM_BOT_TOKEN=
OPENCLAW_ADMIN_TELEGRAM_ID=

# === FastAPI tools backend ===
# Base URL of the Python app (this repo) — usually localhost.
APP_BASE_URL=http://127.0.0.1:8000

# Bearer token for /api/tools/* — must match AGENT_TOOLS_TOKEN in the backend.
# The backend generates one at runtime if empty when it spawns OpenClaw itself.
AGENT_TOOLS_TOKEN=
