# Exchange Order Monitor Bot — configuration template.
# Copy to .env and fill in. DO NOT commit .env.
# Real credentials for the 5 exchanges are in ../test_task.txt (outside the repo).

# Behavior flags (A5, money safety)
DRY_RUN=true
AUTO_ACCEPT_THRESHOLD_COST=0
DAILY_SPEND_LIMIT=1000
PER_ORDER_SPEND_LIMIT=200
DB_PATH=./exchange_monitor.db
ORDER_POLL_INTERVAL_SECONDS=300
POSTS_POLL_INTERVAL_SECONDS=900
METRICA_VERIFICATION_WINDOW_DAYS=7

# Telegram (Day 6)
TELEGRAM_BOT_TOKEN=
# JSON list of admin chat ids, e.g. [123456789]
TELEGRAM_ADMIN_IDS=[]

# Exchange credentials — populate from ../test_task.txt at deploy time
SMMCODE_API_KEY=
PRSKILL_API_KEY=
UNU_API_KEY=
ADVEGO_API_TOKEN=
IPGOLD_API_KEY=

# Yandex Metrica (A10) — empty => TrafficVerifier runs in mock mode
METRICA_COUNTER_ID=
METRICA_OAUTH_TOKEN=

# Google Sheets (A9)
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Targets — A2 (config-driven; never hardcode)
TARGET_WEBSITE_URL=
# JSON list of social account URLs, e.g. ["https://t.me/our_channel"]
TARGET_SOCIAL_ACCOUNTS=[]
