# Task Monitoring Bot — configuration template.
# Copy to .env and fill in. DO NOT commit .env.
# Real credentials are supplied privately during deployment.

# Behavior flags and money safety
DRY_RUN=true
AUTO_ACCEPT_THRESHOLD_COST=0
DAILY_SPEND_LIMIT=1000
PER_ORDER_SPEND_LIMIT=200
AUTO_REJECT_UNCERTAIN_RESULTS=true
DB_PATH=./exchange_monitor.db
ORDER_POLL_INTERVAL_SECONDS=300
POSTS_POLL_INTERVAL_SECONDS=900
METRICA_VERIFICATION_WINDOW_DAYS=7

# Telegram
TELEGRAM_BOT_TOKEN=
# JSON list of admin chat ids, e.g. [123456789]
TELEGRAM_ADMIN_IDS=[]

# Exchange credentials
SMMCODE_API_KEY=
PRSKILL_API_KEY=
UNU_API_KEY=
ADVEGO_API_TOKEN=
IPGOLD_API_KEY=

# Yandex Metrica — empty => TrafficVerifier runs in mock mode
METRICA_COUNTER_ID=
METRICA_OAUTH_TOKEN=

# YouTube Data API — required for live subscriber/like/view baseline checks
YOUTUBE_DATA_API_KEY=

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=

# LLM autopilot (Ollama /api/chat)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=30
AUTOPILOT_CANDIDATE_LIMIT_PER_EXCHANGE=8

# Browser dashboard
WEB_DASHBOARD_HOST=127.0.0.1
WEB_DASHBOARD_PORT=8080
WEB_DASHBOARD_TOKEN=

# Targets (config-driven; never hardcode)
TARGET_WEBSITE_URL=
# JSON list of social account URLs, e.g. ["https://t.me/our_channel"]
TARGET_SOCIAL_ACCOUNTS=[]
